# Remnant Framework — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.

# === REQUIRED ===
# AES-GCM master key for secret encryption (32 bytes, base64-encoded)
# Generate with: python -c "import base64,os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
REMNANT_MASTER_KEY=

# Primary LLM (Anthropic Claude)
ANTHROPIC_API_KEY=

# === OPTIONAL ===
# OpenAI (for embeddings or chat fallback)
OPENAI_API_KEY=

# OpenRouter (cheap fallback models)
OPENROUTER_API_KEY=

# Telegram bot token (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# Redis (if not using Docker)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Ollama (if running locally outside Docker)
OLLAMA_BASE_URL=http://localhost:11434

# Security passphrase (if require_on_startup: true in security.yaml)
REMNANT_PASSPHRASE=

# API server
REMNANT_ENV=development
REMNANT_LOG_LEVEL=INFO
